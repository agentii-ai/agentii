# Agentii Frontend Environment Variables
# Copy to .env.local and fill in your values

# Supabase (get from https://supabase.com/dashboard → Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend gateway WebSocket
VITE_WS_URL=ws://localhost:3100/ws/chat

# Set to false to use real backend instead of mocks
VITE_MOCK_API=false

# Legacy API (kept for backward compat)
VITE_API_URL=http://localhost:8000/api/v1
